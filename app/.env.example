# Backend API base URL.
# Production: https://api.mycongregation.org/api
# Local dev:  http://localhost:3002/api (requires running mycongregation-server)
EXPO_PUBLIC_API_URL=http://localhost:3002/api

# Public VAPID key for Web Push subscription registration.
# Obtain from the backend admin, or generate a key pair with:
#   npx web-push generate-vapid-keys
# Only the PUBLIC half goes here. The private half lives in the
# server's .env as VAPID_PRIVATE_KEY and must never be shipped to clients.
EXPO_PUBLIC_VAPID_KEY=<your-public-vapid-key>
